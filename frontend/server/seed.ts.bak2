  name: string;
  displayName: string;
  description: string;
  character: string;
  keySeed: string;
  rating: number;
  ratingDeviation: number;
  gamesPlayed: number;
  gamesWon: number;
  totalScore: number;
  bestStreak: number;
  karma: number;
  achievements: string[];
}

